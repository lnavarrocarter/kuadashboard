# ─── KuaDashboard — Environment Variables ────────────────────────────────────
# Copy this file to .env and fill in the values relevant to your setup.
# All variables are optional unless marked as REQUIRED.

# ─── Server ──────────────────────────────────────────────────────────────────

# Port the Express backend listens on (default: 7190)
PORT=7190

# ─── Credential Vault ────────────────────────────────────────────────────────

# Passphrase used to encrypt the local vault file (~/.kube/kuadashboard_envs.enc).
# If not set, a machine-derived fallback (hostname + username) is used.
# Recommended: set a strong value in production/shared deployments.
KUADASHBOARD_VAULT_PASS=kuadashboard_secret_passphrase

# Force a specific credential store backend.
# Options: "keytar" (OS native keychain) | unset (auto: keytar in Electron, file elsewhere)
# KUADASHBOARD_STORE=keytar

# ─── Vercel OAuth (optional — only needed for "Connect with Vercel" button) ───
#
# Create an OAuth App at https://vercel.com/account/integrations
# Set the Redirect URI to:
# https://lnavarrocarter.github.io/kuadashboard/vercel-callback
#
# That HTTPS callback performs the second hop to: kua://vercel/callback
#
# Without these, Vercel profiles can still be created manually with an API token.
VERCEL_OAUTH_CLIENT_ID=oac_exampleclientid1234567890
VERCEL_OAUTH_CLIENT_SECRET=exampleclientsecret1234567890abcdef
